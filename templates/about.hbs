<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About Us | KisanVikas</title>
    <link rel="stylesheet" href="/CSS/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        main {
            padding: 50px 4%;
            max-width: 1450px;
            margin: auto;
        }

        .about-section {
            margin-bottom: 40px;
            background: white;
            padding: 35px;
            border-radius: 20px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
            border: 1px solid rgba(30, 92, 55, 0.06);
        }

        .about-section:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
        }

        .about-section h2 {
            color: #123b22;
            font-size: 1.5rem;
            margin-bottom: 16px;
            position: relative;
            padding-bottom: 10px;
        }

        .about-section h2::after {
            content: '';
            display: block;
            width: 50px;
            height: 3px;
            background: linear-gradient(135deg, #1e5c37, #3cab6b);
            margin-top: 8px;
            border-radius: 2px;
        }

        .about-section p {
            font-size: 0.95rem;
            color: #587060;
            line-height: 1.8;
        }

        .about-section h3 {
            color: #1e5c37;
            font-size: 1.1rem;
            margin: 20px 0 8px;
        }

        .vision-mission-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 25px;
        }

        .vm-card {
            background: linear-gradient(135deg, #edf5f0, #f4f8f5);
            padding: 30px;
            border-radius: 16px;
            text-align: center;
            border: 1px solid rgba(60, 171, 107, 0.15);
        }

        .vm-card h2 {
            color: #123b22;
            font-size: 1.3rem;
        }

        .vm-card p {
            font-size: 0.92rem;
            color: #587060;
        }

        ul {
            list-style: none;
            padding: 0;
        }

        ul li {
            padding: 8px 0 8px 20px;
            position: relative;
            font-size: 0.95rem;
            color: #587060;
        }

        ul li::before {
            content: '✓';
            position: absolute;
            left: 0;
            color: #3cab6b;
            font-weight: bold;
        }

        .facility-card {
            background: #f4f8f5;
            padding: 20px;
            border-radius: 12px;
            margin: 15px 0;
            border-left: 4px solid #3cab6b;
            transition: all 0.3s ease;
        }

        .facility-card:hover {
            transform: translateX(5px);
            background: #edf5f0;
        }

        .facility-card h3 {
            color: #123b22;
            margin-bottom: 6px;
            font-size: 1rem;
        }

        .facility-card p {
            font-size: 0.9rem;
            color: #587060;
            margin: 0;
        }

        @media (max-width: 768px) {
            .vision-mission-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>
    <header>
        <div class="header-left">
            <p>Email: support@agriculture.com</p>
            <p>Toll-Free: 1800-123-4567</p>
        </div>
        <div class="header-center">
            <h1>KisanVikas</h1>
            <p>Empowering Farmers, Ensuring Growth</p>
        </div>
        <div class="header-right">
            <a href="/profile">
                <img src="/Assets/woman.png" alt="Profile" class="profile-pic">
            </a>
            {{#if currentUser}}
            <a href="/logout" class="logout-btn">Logout</a>
            {{else}}
            <a href="/" class="logout-btn">Login</a>
            {{/if}}
        </div>
    </header>

    <nav>
        <div class="logo">
            <img src="/Assets/K1.png" alt="Logo">
        </div>
        <div class="menu-toggle" id="mobile-menu">☰</div>
        <div class="nav-links">
            <a href="/index">Home</a>
            <div class="dropdown">
                <a href="#" class="dropdown-btn">Services</a>
                <div class="dropdown-content">
                    <a href="/schemes">Schemes</a>
                    <a href="/crop">Crop Guidance</a>
                    <a href="/loan">Loan Calculator</a>
                </div>
            </div>
            <a href="/about">About</a>
            <a href="/schemes">Schemes</a>
            <a href="/contact">Contact</a>
        </div>
    </nav>

    <main>
        <div class="vision-mission-grid">
            <div class="vm-card">
                <h2><i class="fas fa-eye" style="color:#f0c040;margin-right:8px"></i>Our Vision</h2>
                <p>To revolutionize Indian agriculture by bridging the gap between farmers and essential government
                    resources, financial aid, and innovative farming techniques.</p>
            </div>
            <div class="vm-card">
                <h2><i class="fas fa-bullseye" style="color:#2ecc71;margin-right:8px"></i>Our Mission</h2>
                <p>Deliver accessible, reliable, and real-time support to every farmer through technology — making
                    farming smarter, more profitable, and future-ready.</p>
            </div>
        </div>

        <div class="about-section">
            <h2>Why Choose KisanVikas?</h2>
            <p>We understand farmers' needs and challenges. Our platform offers:</p>
            <ul>
                <li>One-stop access to government schemes, subsidies, and registration assistance.</li>
                <li>Smart loan calculators for transparent financial planning.</li>
                <li>Personalized crop advice based on soil health and local climate.</li>
                <li>Daily updates on market prices and weather conditions.</li>
                <li>Expert-driven video tutorials, workshops, and live Q&A sessions.</li>
                <li>Community forums for farmers to share experiences and solutions.</li>
            </ul>
        </div>

        <div class="about-section">
            <h2>Facilities We Provide</h2>
            <div class="facility-card">
                <h3><i class="fas fa-shield-alt" style="color:#2ecc71;margin-right:8px"></i>Government Schemes and
                    Assistance</h3>
                <p>Explore government initiatives, eligibility checks, easy application guidance, and real-time
                    tracking.</p>
            </div>
            <div class="facility-card">
                <h3><i class="fas fa-calculator" style="color:#f0c040;margin-right:8px"></i>Loan Calculator</h3>
                <p>Instantly estimate loan eligibility, monthly EMI, and get advice on improving creditworthiness.</p>
            </div>
            <div class="facility-card">
                <h3><i class="fas fa-seedling" style="color:#2ecc71;margin-right:8px"></i>Crop and Fertilizer Guidance
                </h3>
                <p>Seasonal crop recommendations, soil testing support, and fertilizer optimization strategies.</p>
            </div>
            <div class="facility-card">
                <h3><i class="fas fa-graduation-cap" style="color:#4a6cf7;margin-right:8px"></i>Educational Resources
                    and Training</h3>
                <p>Rich library of video lessons, expert interviews, cultivation methods, and pest management.</p>
            </div>
            <div class="facility-card">
                <h3><i class="fas fa-handshake" style="color:#e67e22;margin-right:8px"></i>Farmer Support and Community
                </h3>
                <p>24/7 helpdesk, peer-to-peer discussions, and expert forums to solve doubts and share innovations.</p>
            </div>
        </div>
    </main>
    <footer id="modern-footer">
        <div class="modern-footer-container">
            <div class="footer-column-footer-logo">
                <img src="/Assets/K1.png" alt="Logo">
                <p>Your trusted partner for digital solutions.</p>
            </div>
            <div class="footer-column">
                <h2>Follow Us</h2>
                <div class="modern-footer-icons">
                    <a href="#"><img src="/Assets/facebook.png" alt="Facebook"></a>
                    <a href="#"><img src="/Assets/twitter.png" alt="Twitter"></a>
                    <a href="#"><img src="/Assets/instagram.png" alt="Instagram"></a>
                    <a href="#"><img src="/Assets/linkedin.png" alt="LinkedIn"></a>
                </div>
            </div>
            <div class="footer-column">
                <h2>Quick Links</h2>
                <ul class="modern-footer-links">
                    <li><a href="/index">Home</a></li>
                    <li><a href="/loan">Loan Calculator</a></li>
                    <li><a href="/schemes">Schemes</a></li>
                    <li><a href="/crop">Crop Guidance</a></li>
                    <li><a href="/about">About Us</a></li>
                    <li><a href="/contact">Contact</a></li>
                </ul>
            </div>
            <div class="footer-column">
                <h2>Contact</h2>
                <ul class="modern-footer-contact">
                    <li><i class="fas fa-map-marker-alt"></i> PCCOE, Pune</li>
                    <li><i class="fas fa-phone"></i> Toll-Free: 1800-123-4567</li>
                    <li><i class="fas fa-envelope"></i> support@agriculture.com</li>
                    <li><i class="fas fa-comment-dots"></i> <a href="https://forms.gle/E5sQEWYuMW8FFmyN9">Give
                            Feedback</a></li>
                </ul>
            </div>
        </div>
        <div class="modern-footer-bottom">
            <p>&copy; 2025 KisanVikas | <a href="/policy">Privacy Policy</a></p>
        </div>
    </footer>

    <script>
        const mobileMenu = document.getElementById("mobile-menu");
        if (mobileMenu) {
            mobileMenu.addEventListener("click", function () {
                document.querySelector(".nav-links").classList.toggle("active");
            });
        }
    </script>
</body>

</html>