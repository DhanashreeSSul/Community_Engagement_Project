<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KisanVikas | Empowering Farmers</title>
    <link rel="stylesheet" href="/CSS/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body>
    <header>
        <div class="header-left">
            <p>Email: support@agriculture.com</p>
            <p>Toll-Free: 1800-123-4567</p>
        </div>
        <div class="header-center">
            <h1>KisanVikas</h1>
            <p>Empowering Farmers, Ensuring Growth</p>
        </div>
        <div class="header-right">
            <a href="/profile">
                <img src="/Assets/woman.png" alt="Profile" class="profile-pic">
            </a>
            {{#if currentUser}}
            <a href="/logout" class="logout-btn">Logout</a>
            {{else}}
            <a href="/" class="logout-btn">Login</a>
            {{/if}}
        </div>
    </header>

    <nav>
        <div class="logo">
            <img src="/Assets/K1.png" alt="Logo">
        </div>
        <div class="menu-toggle" id="mobile-menu">☰</div>
        <div class="nav-links">
            <a href="/index">Home</a>
            <div class="dropdown">
                <a href="#" class="dropdown-btn">Services</a>
                <div class="dropdown-content">
                    <a href="/schemes">Schemes</a>
                    <a href="/crop">Crop Guidance</a>
                    <a href="/loan">Loan Calculator</a>
                </div>
            </div>
            <a href="/about">About</a>
            <a href="/schemes">Schemes</a>
            <a href="/contact">Contact</a>
        </div>
    </nav>

    <div class="popup" id="popup">
        <span class="close-btn" id="close-popup">✕</span>
        <div class="popup-content">
            <h3>Welcome to KisanVikas!</h3>
            <p>Discover sustainable practices and resources to revolutionize your agriculture techniques.</p>

            <section class="vision-mission">
                <div class="box vision">
                    <h2>Our Vision</h2>
                    <p>We aim to bridge the gap between farmers and essential government resources, empowering them with
                        financial aid, modern farming techniques, and real-time information.</p>
                </div>
                <div class="box mission">
                    <h2>Our Mission</h2>
                    <p>To provide farmers with easy access to government schemes, financial planning tools, and
                        crop-specific guidance, ensuring sustainable and profitable farming practices.</p>
                </div>
            </section>

            <section class="why-choose">
                <h2>Why Choose KisanVikas?</h2>
                <p>Our platform is built with the needs of farmers in mind, offering:</p>
                <ul>
                    <li>Easy Access to all government schemes & farming resources.</li>
                    <li>Smart Loan Calculators for financial planning.</li>
                    <li>Crop-Specific Advice based on soil & climate conditions.</li>
                    <li>Real-Time Market Prices & Weather Alerts to maximize profits.</li>
                    <li>Expert Guidance & Training through video tutorials & workshops.</li>
                </ul>
            </section>

            <section class="facilities">
                <h2>Facilities We Provide</h2>
                <div class="facility">
                    <h3>Government Schemes & Assistance</h3>
                    <p>List of available schemes, eligibility checks, and application tracking.</p>
                </div>
                <div class="facility">
                    <h3>Loan Calculator</h3>
                    <p>Estimate loan eligibility, calculate EMIs, and plan finances wisely.</p>
                </div>
                <div class="facility">
                    <h3>Crop & Fertilizer Guidance</h3>
                    <p>Best crop & fertilizer recommendations based on soil type and season.</p>
                </div>
                <div class="facility">
                    <h3>Educational Resources & Training</h3>
                    <p>Video tutorials, online workshops, and step-by-step farming guides.</p>
                </div>
            </section>
        </div>
    </div>

    <section class="welcome">
        <div class="welcome-text">
            <h1>Welcome to the Future of Agriculture</h1>
            <p>Empowering Farmers with Schemes and Resources</p>
        </div>
    </section>

    <section class="offerings">
        <h2>Our Offerings</h2>
        <div class="offerings-container">
            <a href="/loan" class="card">
                <img src="/Assets/calculating.png" alt="Loan Calculator">
                <h3>Loan Calculator</h3>
            </a>
            <a href="/schemes" class="card">
                <img src="/Assets/bank.png" alt="Government Schemes">
                <h3>Government Schemes</h3>
            </a>
            <a href="/crop" class="card">
                <img src="/Assets/fertilizer.png" alt="Crop Guidance">
                <h3>Crop Guidance</h3>
            </a>
        </div>
    </section>

    <section class="strengths">
        <h2>OUR STRENGTHS</h2>
        <div class="strengths-container">
            <div class="strength">
                <img src="/Assets/user-friendly.png" alt="User Friendly">
                <h3>User-Friendliness</h3>
                <p>The project is designed with a simple, intuitive interface that makes it easy for farmers to access
                    information. Whether using a mobile or website, the user experience is streamlined for all levels.
                </p>
            </div>
            <div class="strength">
                <img src="/Assets/educational-video.png" alt="Videos">
                <h3>Videos for Easy Understanding</h3>
                <p>Informative and engaging video tutorials visually explain various farming techniques, solutions, and
                    how to utilize government schemes for a practical learning experience.</p>
            </div>
            <div class="strength">
                <img src="/Assets/awareness.png" alt="Solutions">
                <h3>Crop Problems & Solutions</h3>
                <p>Access a comprehensive database of common crop issues like pest infestations, diseases, and soil
                    health problems with practical solutions and recommendations.</p>
            </div>
            <div class="strength">
                <img src="/Assets/megaphone.png" alt="Schemes">
                <h3>Schemes Info & Description</h3>
                <p>Up-to-date information on government schemes, subsidies, and financial aid programs with detailed
                    descriptions and step-by-step guides for farmers.</p>
            </div>
        </div>
    </section>

    <footer id="modern-footer">
        <div class="modern-footer-container">
            <div class="footer-column-footer-logo">
                <img src="/Assets/K1.png" alt="Logo">
                <p>Your trusted partner for digital solutions.</p>
            </div>
            <div class="footer-column">
                <h2>Follow Us</h2>
                <div class="modern-footer-icons">
                    <a href="#"><img src="/Assets/facebook.png" alt="Facebook"></a>
                    <a href="#"><img src="/Assets/twitter.png" alt="Twitter"></a>
                    <a href="#"><img src="/Assets/instagram.png" alt="Instagram"></a>
                    <a href="#"><img src="/Assets/linkedin.png" alt="LinkedIn"></a>
                </div>
            </div>
            <div class="footer-column">
                <h2>Quick Links</h2>
                <ul class="modern-footer-links">
                    <li><a href="/index">Home</a></li>
                    <li><a href="/loan">Loan Calculator</a></li>
                    <li><a href="/schemes">Schemes</a></li>
                    <li><a href="/crop">Crop Guidance</a></li>
                    <li><a href="/about">About Us</a></li>
                    <li><a href="/contact">Contact</a></li>
                </ul>
            </div>
            <div class="footer-column">
                <h2>Contact</h2>
                <ul class="modern-footer-contact">
                    <li><i class="fas fa-map-marker-alt"></i> PCCOE, Pune</li>
                    <li><i class="fas fa-phone"></i> Toll-Free: 1800-123-4567</li>
                    <li><i class="fas fa-envelope"></i> support@agriculture.com</li>
                    <li><i class="fas fa-comment-dots"></i> <a href="https://forms.gle/E5sQEWYuMW8FFmyN9">Give
                            Feedback</a></li>
                </ul>
            </div>
        </div>
        <div class="modern-footer-bottom">
            <p>&copy; 2025 KisanVikas | <a href="/policy">Privacy Policy</a></p>
        </div>
    </footer>

    <script src="/js/scripts.js"></script>
</body>

</html>