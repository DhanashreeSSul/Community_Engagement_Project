<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Farmer Profile | KisanVikas</title>
    <link rel="stylesheet" href="/CSS/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        .profile-dashboard {
            max-width: 1450px;
            margin: 40px auto;
            padding: 0 4%;
        }

        .profile-hero {
            background: linear-gradient(135deg, #123b22 0%, #1e5c37 50%, #3cab6b 100%);
            border-radius: 24px;
            padding: 40px;
            display: flex;
            align-items: center;
            gap: 30px;
            color: white;
            box-shadow: 0 8px 35px rgba(0, 0, 0, 0.15);
            position: relative;
            overflow: hidden;
        }

        .profile-hero::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(229, 181, 79, 0.1) 0%, transparent 70%);
            border-radius: 50%;
        }

        .profile-avatar {
            width: 130px;
            height: 130px;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid rgba(229, 181, 79, 0.6);
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
            flex-shrink: 0;
        }

        .profile-details h2 {
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 6px;
        }

        .profile-details .info-row {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            margin-top: 12px;
        }

        .info-item {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.9rem;
            opacity: 0.9;
        }

        .info-item i {
            color: #e5b54f;
            width: 16px;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin: 30px 0;
        }

        .stat-card {
            background: white;
            border-radius: 16px;
            padding: 25px 20px;
            text-align: center;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            border: 1px solid rgba(30, 92, 55, 0.08);
            transition: all 0.3s ease;
        }

        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
        }

        .stat-card i {
            font-size: 1.5rem;
            color: #3cab6b;
            margin-bottom: 10px;
        }

        .stat-card .stat-number {
            font-size: 1.6rem;
            font-weight: 700;
            color: #123b22;
        }

        .stat-card .stat-label {
            font-size: 0.78rem;
            color: #587060;
            margin-top: 4px;
        }

        .schemes-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 25px;
            margin-bottom: 40px;
        }

        .scheme-panel {
            background: white;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
            border: 1px solid rgba(30, 92, 55, 0.08);
        }

        .scheme-panel h3 {
            font-size: 1.1rem;
            font-weight: 600;
            color: #123b22;
            margin-bottom: 18px;
            padding-bottom: 12px;
            border-bottom: 2px solid #edf5f0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .scheme-panel h3 i {
            font-size: 1.2rem;
        }

        .scheme-panel ul {
            list-style: none;
            padding: 0;
        }

        .scheme-panel ul li {
            padding: 10px 14px;
            margin-bottom: 8px;
            background: #f4f8f5;
            border-radius: 10px;
            font-size: 0.88rem;
            color: #333;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: all 0.3s ease;
        }

        .scheme-panel ul li:hover {
            background: #edf5f0;
            transform: translateX(4px);
        }

        .scheme-panel ul li::before {
            content: '●';
            color: #3cab6b;
            font-size: 0.6rem;
        }

        .scheme-form {
            display: flex;
            gap: 10px;
            margin-top: 15px;
        }

        .scheme-form input {
            flex: 1;
            padding: 10px 14px;
            border: 2px solid #e0e8e2;
            border-radius: 10px;
            font-family: 'Poppins', sans-serif;
            font-size: 0.85rem;
            transition: all 0.3s ease;
        }

        .scheme-form input:focus {
            outline: none;
            border-color: #3cab6b;
        }

        .scheme-form button {
            background: linear-gradient(135deg, #1e5c37 0%, #3cab6b 100%);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 10px;
            font-family: 'Poppins', sans-serif;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            white-space: nowrap;
        }

        .scheme-form button:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(60, 171, 107, 0.25);
        }

        @media (max-width: 768px) {
            .profile-hero {
                flex-direction: column;
                text-align: center;
                padding: 30px 20px;
            }

            .profile-details .info-row {
                justify-content: center;
            }

            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .schemes-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>
    <header>
        <div class="header-left">
            <p>Email: support@agriculture.com</p>
            <p>Toll-Free: 1800-123-4567</p>
        </div>
        <div class="header-center">
            <h1>KisanVikas</h1>
            <p>Empowering Farmers, Ensuring Growth</p>
        </div>
        <div class="header-right">
            <a href="/profile">
                <img src="/uploads/{{photo}}" alt="Profile" class="profile-pic" onerror="this.src='/Assets/woman.png'">
            </a>
            <a href="/logout" class="logout-btn">Logout</a>
        </div>
    </header>

    <nav>
        <div class="logo">
            <img src="/Assets/K1.png" alt="Logo">
        </div>
        <div class="menu-toggle" id="mobile-menu">☰</div>
        <div class="nav-links">
            <a href="/index">Home</a>
            <div class="dropdown">
                <a href="#" class="dropdown-btn">Services</a>
                <div class="dropdown-content">
                    <a href="/schemes">Schemes</a>
                    <a href="/crop">Crop Guidance</a>
                    <a href="/loan">Loan Calculator</a>
                </div>
            </div>
            <a href="/about">About</a>
            <a href="/schemes">Schemes</a>
            <a href="/contact">Contact</a>
        </div>
    </nav>

    <div class="profile-dashboard">
        <!-- Profile Hero -->
        <div class="profile-hero">
            <img src="/uploads/{{photo}}" alt="Profile Photo" class="profile-avatar"
                onerror="this.src='/Assets/woman.png'">
            <div class="profile-details">
                <h2>{{username}}</h2>
                <div class="info-row">
                    <div class="info-item"><i class="fas fa-envelope"></i> {{email}}</div>
                    <div class="info-item"><i class="fas fa-map-marker-alt"></i> {{location}}</div>
                    <div class="info-item"><i class="fas fa-ruler-combined"></i> {{landSize}} acres</div>
                    <div class="info-item"><i class="fas fa-seedling"></i> {{crops}}</div>
                </div>
            </div>
        </div>

        <!-- Stats Cards -->
        <div class="stats-grid">
            <div class="stat-card">
                <i class="fas fa-file-alt"></i>
                <div class="stat-number">{{appliedSchemes.length}}</div>
                <div class="stat-label">Applied Schemes</div>
            </div>
            <div class="stat-card">
                <i class="fas fa-check-circle"></i>
                <div class="stat-number">{{eligibleSchemes.length}}</div>
                <div class="stat-label">Eligible Schemes</div>
            </div>
            <div class="stat-card">
                <i class="fas fa-ruler-combined"></i>
                <div class="stat-number">{{landSize}}</div>
                <div class="stat-label">Acres of Land</div>
            </div>
            <div class="stat-card">
                <i class="fas fa-calendar-alt"></i>
                <div class="stat-number" style="font-size:1rem">{{memberSince}}</div>
                <div class="stat-label">Member Since</div>
            </div>
        </div>

        <!-- Schemes Panels -->
        <div class="schemes-grid">
            <div class="scheme-panel">
                <h3><i class="fas fa-check-double" style="color:#2ecc71"></i> Applied Schemes</h3>
                <ul>
                    {{#if appliedSchemes.length}}
                    {{#each appliedSchemes}}
                    <li>{{this}}</li>
                    {{/each}}
                    {{else}}
                    <li>No applied schemes yet.</li>
                    {{/if}}
                </ul>
                <form action="/add-applied-scheme" method="POST" class="scheme-form">
                    <input type="text" name="schemeName" placeholder="Add new scheme..." required>
                    <button type="submit"><i class="fas fa-plus"></i> Add</button>
                </form>
            </div>

            <div class="scheme-panel">
                <h3><i class="fas fa-star" style="color:#f0c040"></i> Eligible Schemes</h3>
                <ul>
                    {{#if eligibleSchemes.length}}
                    {{#each eligibleSchemes}}
                    <li>{{this}}</li>
                    {{/each}}
                    {{else}}
                    <li>No eligible schemes listed.</li>
                    {{/if}}
                </ul>
                <form action="/add-eligible-scheme" method="POST" class="scheme-form">
                    <input type="text" name="schemeName" placeholder="Add new scheme..." required>
                    <button type="submit"><i class="fas fa-plus"></i> Add</button>
                </form>
            </div>
        </div>
    </div>
    <footer id="modern-footer">
        <div class="modern-footer-container">
            <div class="footer-column-footer-logo">
                <img src="/Assets/K1.png" alt="Logo">
                <p>Your trusted partner for digital solutions.</p>
            </div>
            <div class="footer-column">
                <h2>Follow Us</h2>
                <div class="modern-footer-icons">
                    <a href="#"><img src="/Assets/facebook.png" alt="Facebook"></a>
                    <a href="#"><img src="/Assets/twitter.png" alt="Twitter"></a>
                    <a href="#"><img src="/Assets/instagram.png" alt="Instagram"></a>
                    <a href="#"><img src="/Assets/linkedin.png" alt="LinkedIn"></a>
                </div>
            </div>
            <div class="footer-column">
                <h2>Quick Links</h2>
                <ul class="modern-footer-links">
                    <li><a href="/index">Home</a></li>
                    <li><a href="/loan">Loan Calculator</a></li>
                    <li><a href="/schemes">Schemes</a></li>
                    <li><a href="/crop">Crop Guidance</a></li>
                    <li><a href="/about">About Us</a></li>
                    <li><a href="/contact">Contact</a></li>
                </ul>
            </div>
            <div class="footer-column">
                <h2>Contact</h2>
                <ul class="modern-footer-contact">
                    <li><i class="fas fa-map-marker-alt"></i> PCCOE, Pune</li>
                    <li><i class="fas fa-phone"></i> Toll-Free: 1800-123-4567</li>
                    <li><i class="fas fa-envelope"></i> support@agriculture.com</li>
                    <li><i class="fas fa-comment-dots"></i> <a href="https://forms.gle/E5sQEWYuMW8FFmyN9">Give
                            Feedback</a></li>
                </ul>
            </div>
        </div>
        <div class="modern-footer-bottom">
            <p>&copy; 2025 KisanVikas | <a href="/policy">Privacy Policy</a></p>
        </div>
    </footer>

    <script>
        const mobileMenu = document.getElementById("mobile-menu");
        if (mobileMenu) {
            mobileMenu.addEventListener("click", function () {
                document.querySelector(".nav-links").classList.toggle("active");
            });
        }
    </script>
</body>

</html>