<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Government Schemes | KisanVikas</title>
  <link rel="stylesheet" href="/CSS/stylesschemes.css">
  <link rel="stylesheet" href="/CSS/styles.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body>
  <header>
    <div class="header-left">
      <p>Email: support@agriculture.com</p>
      <p>Toll-Free: 1800-123-4567</p>
    </div>
    <div class="header-center">
      <h1>KisanVikas</h1>
      <p>Government Schemes Portal</p>
    </div>
    <div class="header-right">
      <a href="/profile">
        <img src="/Assets/woman.png" alt="Profile" class="profile-pic">
      </a>
      {{#if currentUser}}
      <a href="/logout" class="logout-btn">Logout</a>
      {{else}}
      <a href="/" class="logout-btn">Login</a>
      {{/if}}
    </div>
  </header>

  <nav>
    <div class="logo">
      <img src="/Assets/K1.png" alt="Logo">
    </div>
    <div class="menu-toggle" id="mobile-menu">☰</div>
    <div class="nav-links">
      <a href="/index">Home</a>
      <div class="dropdown">
        <a href="#" class="dropdown-btn">Services</a>
        <div class="dropdown-content">
          <a href="/schemes">Schemes</a>
          <a href="/crop">Crop Guidance</a>
          <a href="/loan">Loan Calculator</a>
        </div>
      </div>
      <a href="/about">About</a>
      <a href="/schemes">Schemes</a>
      <a href="/contact">Contact</a>
    </div>
  </nav>

  <div class="container">
    <h2>Available Schemes</h2>

    <div class="filters">
      <select id="typeFilter">
        <option value="">All Types</option>
        <option value="Central">Central Scheme</option>
        <option value="State">State Scheme</option>
      </select>
      <select id="residenceFilter">
        <option value="">All Residences</option>
        <option value="Rural">Rural</option>
        <option value="Urban">Urban</option>
      </select>
      <select id="occupationFilter">
        <option value="">All Occupations</option>
        <option value="Farmer">Farmer</option>
        <option value="Fisher">Fisher</option>
        <option value="Entrepreneur">Entrepreneur</option>
      </select>
    </div>

    <div id="schemeCountContainer">
      <h3 id="schemeCount">Loading schemes...</h3>
    </div>

    <div id="schemeResults" class="schemes"></div>
  </div>

  <footer id="modern-footer">
    <div class="modern-footer-container">
      <div class="footer-column-footer-logo">
        <img src="/Assets/K1.png" alt="Logo">
        <p>Your trusted partner for digital solutions.</p>
      </div>
      <div class="footer-column">
        <h2>Follow Us</h2>
        <div class="modern-footer-icons">
          <a href="#"><img src="/Assets/facebook.png" alt="Facebook"></a>
          <a href="#"><img src="/Assets/twitter.png" alt="Twitter"></a>
          <a href="#"><img src="/Assets/instagram.png" alt="Instagram"></a>
          <a href="#"><img src="/Assets/linkedin.png" alt="LinkedIn"></a>
        </div>
      </div>
      <div class="footer-column">
        <h2>Quick Links</h2>
        <ul class="modern-footer-links">
          <li><a href="/index">Home</a></li>
          <li><a href="/loan">Loan Calculator</a></li>
          <li><a href="/schemes">Schemes</a></li>
          <li><a href="/crop">Crop Guidance</a></li>
          <li><a href="/about">About Us</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer-column">
        <h2>Contact</h2>
        <ul class="modern-footer-contact">
          <li><i class="fas fa-map-marker-alt"></i> PCCOE, Pune</li>
          <li><i class="fas fa-phone"></i> Toll-Free: 1800-123-4567</li>
          <li><i class="fas fa-envelope"></i> support@agriculture.com</li>
          <li><i class="fas fa-comment-dots"></i> <a href="https://forms.gle/E5sQEWYuMW8FFmyN9">Give Feedback</a></li>
        </ul>
      </div>
    </div>
    <div class="modern-footer-bottom">
      <p>&copy; 2025 KisanVikas | <a href="/policy">Privacy Policy</a></p>
    </div>
  </footer>

  <script>
    // Schemes data from MongoDB (injected by server)
    const schemes = {{{ schemes }}};

    const schemeContainer = document.getElementById("schemeResults");
    const schemeCountEl = document.getElementById("schemeCount");

    function renderSchemes(data) {
      schemeCountEl.textContent = `Showing ${data.length} of ${schemes.length} Schemes`;
      schemeContainer.innerHTML = data.map(scheme => `
                <div class="scheme-card">
                    <span class="badge ${scheme.type === 'Central' ? 'badge-central' : 'badge-state'}">${scheme.type}</span>
                    <span class="badge" style="background:rgba(100,100,255,0.1);color:#4a6cf7">${scheme.occupation}</span>
                    <h3>${scheme.name}</h3>
                    <p><strong>Launched By:</strong> ${scheme.launchedBy}</p>
                    <p><strong>Objective:</strong> ${scheme.objective}</p>
                    <p><strong>Key Features:</strong> ${scheme.features}</p>
                    <p><strong>Eligibility:</strong> ${scheme.eligibility}</p>
                    <a class="learn-more" href="${scheme.link}" target="_blank">Learn More →</a>
                </div>
            `).join("");
    }

    function applyFilters() {
      const type = document.getElementById("typeFilter").value;
      const residence = document.getElementById("residenceFilter").value;
      const occupation = document.getElementById("occupationFilter").value;

      const filtered = schemes.filter(scheme =>
        (!type || scheme.type === type) &&
        (!residence || scheme.residence === residence) &&
        (!occupation || scheme.occupation === occupation)
      );

      renderSchemes(filtered);
    }

    document.getElementById("typeFilter").addEventListener("change", applyFilters);
    document.getElementById("residenceFilter").addEventListener("change", applyFilters);
    document.getElementById("occupationFilter").addEventListener("change", applyFilters);

    renderSchemes(schemes);
  </script>

  <script>
    const mobileMenu = document.getElementById("mobile-menu");
    if (mobileMenu) {
      mobileMenu.addEventListener("click", function () {
        document.querySelector(".nav-links").classList.toggle("active");
      });
    }
  </script>
</body>

</html>